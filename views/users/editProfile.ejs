<% layout("/layouts/boilerplate") %>

<div class="container py-5 fade-in-up">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="p-4 bg-white rounded-4 shadow-soft border">
                <h3 class="fw-bold text-dark mb-4">Edit Profile</h3>
                
                <form action="/profile" method="POST" enctype="multipart/form-data" novalidate class="needs-validation">
                    <div class="mb-4 text-center">
                        <div class="position-relative d-inline-block">
                            <% if (currUser.image && currUser.image.url) { %>
                                <img src="<%= currUser.image.url %>" class="rounded-circle border" style="width: 120px; height: 120px; object-fit: cover;" id="profilePreview">
                            <% } else { %>
                                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white shadow-sm" style="width: 120px; height: 120px; font-size: 3rem; background: linear-gradient(135deg, var(--accent-main), #8fa191);" id="profilePreview">
                                    <%= currUser.username.charAt(0).toUpperCase() %>
                                </div>
                            <% } %>
                            <label for="profileImage" class="position-absolute bottom-0 end-0 bg-white rounded-circle shadow-sm border d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; cursor: pointer;">
                                <i class="fa-solid fa-camera text-muted"></i>
                                <input type="file" id="profileImage" name="user[image]" class="d-none" accept="image/*" onchange="previewImage(this)">
                            </label>
                        </div>
                        <p class="text-muted mt-2" style="font-size: 0.85rem;">Click camera to change photo</p>
                    </div>

                    <div class="mb-3">
                        <label for="username" class="form-label text-muted fw-medium" style="font-size: 0.85rem;">Username</label>
                        <input type="text" id="username" name="username" value="<%= currUser.username %>" class="form-control rounded-3 py-2" required>
                    </div>

                    <div class="mb-4">
                        <label for="email" class="form-label text-muted fw-medium" style="font-size: 0.85rem;">Email Address</label>
                        <input type="email" id="email" name="email" value="<%= currUser.email %>" class="form-control rounded-3 py-2" required>
                    </div>

                    <div class="d-flex gap-2">
                        <a href="/profile" class="btn btn-outline-secondary w-100 rounded-pill py-2 fw-medium">Cancel</a>
                        <button type="submit" class="btn btn-primary-smooth w-100 rounded-pill py-2 fw-bold">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.getElementById('profilePreview');
                if (preview.tagName === 'IMG') {
                    preview.src = e.target.result;
                } else {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'rounded-circle border';
                    img.id = 'profilePreview';
                    img.style.width = '120px';
                    img.style.height = '120px';
                    img.style.objectFit = 'cover';
                    preview.parentNode.replaceChild(img, preview);
                }
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
