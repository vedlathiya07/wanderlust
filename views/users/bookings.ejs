<% layout("/layouts/boilerplate") %>

<div class="container py-5 fade-in-up">
    <div class="d-flex align-items-center gap-3 mb-5">
        <div class="rounded-3 d-flex align-items-center justify-content-center" style="width: 52px; height: 52px; background: rgba(92,113,94,0.1);">
            <i class="fa-solid fa-calendar-check" style="color: var(--accent-main); font-size: 1.3rem;"></i>
        </div>
        <div>
            <h2 class="fw-bold text-dark mb-0">My Bookings</h2>
            <p class="text-muted mb-0" style="font-size: 0.9rem;">Manage your upcoming and past reservations</p>
        </div>
    </div>

    <!-- Filter tabs -->
    <ul class="nav nav-pills mb-4 bg-light rounded-3 p-2 shadow-sm" id="bookingFilters" style="width: fit-content; gap: 4px; border: 1px solid rgba(0,0,0,0.05);">
        <li class="nav-item">
            <button class="nav-link active rounded-3 fw-bold filter-btn" data-filter="all" style="font-size: 0.82rem; padding: 10px 20px;">All</button>
        </li>
        <li class="nav-item">
            <button class="nav-link rounded-3 fw-bold filter-btn text-dark" data-filter="upcoming" style="font-size: 0.82rem; padding: 10px 20px;">Upcoming</button>
        </li>
        <li class="nav-item">
            <button class="nav-link rounded-3 fw-bold filter-btn text-dark" data-filter="completed" style="font-size: 0.82rem; padding: 10px 20px;">Completed</button>
        </li>
        <li class="nav-item">
            <button class="nav-link rounded-3 fw-bold filter-btn text-dark" data-filter="cancelled" style="font-size: 0.82rem; padding: 10px 20px;">Cancelled</button>
        </li>
    </ul>

    <% if (!bookings || bookings.length === 0) { %>
        <!-- Empty state -->
        <div class="text-center py-5 bg-white rounded-4 border shadow-soft" style="max-width: 560px; margin: 0 auto;">
            <div class="mb-4">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 90px; height: 90px; background: rgba(92,113,94,0.08);">
                    <i class="fa-solid fa-suitcase-rolling text-muted" style="font-size: 2.2rem;"></i>
                </div>
                <h4 class="fw-bold text-dark mb-2">No trips booked yet</h4>
                <p class="text-muted mx-auto" style="font-size: 0.95rem; max-width: 340px; line-height: 1.7;">Once you book a stay, it will appear here. Find your next perfect escape on Wanderlust.</p>
            </div>
            <a href="/listings" class="btn btn-primary-smooth px-5 py-2 shadow-soft">
                <i class="fa-solid fa-magnifying-glass me-2"></i>Start Exploring
            </a>
        </div>
    <% } else { %>
        <div class="row g-4" id="bookingsContainer">
            <% for (let booking of bookings) { %>
                <div class="col-md-6 col-lg-4 booking-card-item" data-status="<%= booking.status %>">
                    <div class="property-card-smooth h-100">
                        <div class="property-img-wrapper">
                            <% 
                                let bookingImg = "https://images.unsplash.com/photo-1542314831-c6a4d27160c9?auto=format&fit=crop&w=1920&q=80";
                                if (booking.listing && booking.listing.images && booking.listing.images.length > 0) {
                                    bookingImg = booking.listing.images[0].url;
                                } else if (booking.listing && booking.listing.image && booking.listing.image.url) {
                                    bookingImg = booking.listing.image.url;
                                }
                            %>
                            <img src="<%= bookingImg %>" class="property-img" alt="listing_image">
                            <div class="position-absolute top-0 end-0 m-3">
                                <% 
                                    let badgeType = "bg-white text-dark";
                                    if(booking.status === 'upcoming') badgeType = "bg-success text-white";
                                    if(booking.status === 'cancelled') badgeType = "bg-danger text-white";
                                    if(booking.status === 'completed') badgeType = "bg-secondary text-white";
                                    let inlineStyle = (booking.status === 'upcoming') ? 'background-color: var(--accent-main) !important;' : '';
                                %>
                                <span class="badge rounded-pill shadow-sm px-3 py-2 fw-bold <%= badgeType %>" style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.5px; border: 1px solid rgba(0,0,0,0.05); <%= inlineStyle %>">
                                    <%= booking.status %>
                                </span>
                            </div>
                        </div>
                        <div class="property-info p-3 <%= booking.status === 'cancelled' ? 'opacity-75' : '' %>">
                            <h6 class="fw-bold text-dark mb-2"><%= booking.listing ? booking.listing.title : 'Property' %></h6>
                            <p class="text-muted mb-3" style="font-size: 0.85rem;"><i class="fa-solid fa-calendar-days me-2"></i><%= new Date(booking.checkIn).toLocaleDateString() %> - <%= new Date(booking.checkOut).toLocaleDateString() %></p>
                            <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                                <span class="text-muted" style="font-size: 0.85rem;">Total Paid</span>
                                <span class="fw-bold text-dark">&#8377; <%= booking.totalPrice.toLocaleString("en-IN") %></span>
                            </div>
                            <% if (booking.status === 'upcoming') { %>
                                <form action="/listings/<%= encodeId(booking.listing._id) %>/bookings/<%= encodeId(booking._id) %>?_method=DELETE" method="POST" class="mt-3 m-0">
                                    <button class="btn btn-outline-soft btn-sm w-100 py-2" style="border-color: #f1f1f1 !important; color: #d9534f; font-size: 0.8rem;">Cancel Trip</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    <% } %>

    <script>
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const filter = btn.dataset.filter;
                
                // UI Update
                document.querySelectorAll('.filter-btn').forEach(b => {
                    b.classList.remove('active', 'btn-primary-smooth');
                    b.classList.add('text-dark');
                    b.style.background = 'transparent';
                });
                btn.classList.add('active');
                btn.classList.remove('text-dark');
                btn.style.background = 'var(--accent-main)';
                btn.style.color = 'white';

                // Logic Update
                const items = document.querySelectorAll('.booking-card-item');
                items.forEach(item => {
                    if (filter === 'all' || item.dataset.status === filter) {
                        item.classList.remove('d-none');
                    } else {
                        item.classList.add('d-none');
                    }
                });
            });
        });
    </script>

    <!-- CTA -->
    <div class="mt-5 mb-5 p-4 rounded-4 d-flex align-items-center justify-content-between gap-4 border" style="background: linear-gradient(135deg, rgba(92,113,94,0.07), rgba(92,113,94,0.02));">
        <div>
            <h5 class="fw-bold text-dark mb-1">Have a property to share?</h5>
            <p class="text-muted mb-0" style="font-size: 0.9rem;">List your home and start earning with Wanderlust.</p>
        </div>
        <a href="/listings/new" class="btn btn-primary-smooth px-4 flex-shrink-0 shadow-soft">List Your Property</a>
    </div>
</div>
